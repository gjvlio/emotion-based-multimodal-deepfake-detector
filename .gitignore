# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
venv/
env/
.venv/
.env
.env.local

# =============================================================================
# Raw datasets  (too large — see data/raw/README.md for download instructions)
# =============================================================================
data/raw/*/
!data/raw/README.md

# =============================================================================
# Processed / generated data  (regenerated by pipeline scripts)
# =============================================================================
data/processed/rvc_datasets/
data/synthetic/

# =============================================================================
# Third-party tools  (clone separately — see tools/README.md)
# =============================================================================
tools/Applio/
tools/Wav2Lip/
tools/Hallo/

# =============================================================================
# Audio / video files anywhere in the repo
# =============================================================================
*.wav
*.flv
*.mp4
*.mp3
*.ogg
*.flac
*.m4a
*.avi
*.mkv
*.mov

# =============================================================================
# Large model / index binaries
# =============================================================================
*.pth
*.pt
*.onnx
*.bin
*.safetensors
*.index
*.npy

# =============================================================================
# IDE / OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# Claude Code local config (machine-specific, not project-wide)
# =============================================================================
.claude/settings.local.json
.claude/scheduled_tasks.lock
